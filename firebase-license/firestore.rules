rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /licencas/{codigo} {
      // Leitura pública por ID exato (necessária para o app validar a licença).
      allow get: if true;
      // Nunca permitir listar/enumerar todas as licenças.
      allow list: if false;
      // Só permite atualizar o campo "maquinas" (registro de aparelho ativado).
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['maquinas']);
      // Criação/exclusão só autenticado como o usuário admin do gerador de licenças.
      allow create, delete: if request.auth != null && request.auth.uid == 'ex4yoGofAySjjic3wq3VU0DYf8F3';
      // Admin também pode corrigir qualquer campo (ex: revogar, mudar limite de aparelhos).
      allow update: if request.auth != null && request.auth.uid == 'ex4yoGofAySjjic3wq3VU0DYf8F3';
    }
  }
}
